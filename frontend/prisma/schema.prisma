generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  email     String   @unique
  name      String?
  surname   String?
}

model Service {
  id            String   @id @default(uuid())
  order         Int
  titleEn       String   @map("title_en")
  titleAr       String   @map("title_ar")
  descriptionEn String   @map("description_en")
  descriptionAr String   @map("description_ar")
  published     Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  type          String   @default("Other")
  


  @@map("services")
  @@index([published, order])
}

model Project {
  id            String   @id @default(uuid())
  order         Int
  images        String[] @default([])
  categoryEn    String   @map("category_en")
  categoryAr    String   @map("category_ar")
  titleEn       String   @map("title_en")
  titleAr       String   @map("title_ar")
  descriptionEn String   @map("description_en")
  descriptionAr String   @map("description_ar")
  featured      Boolean  @default(false)
  published     Boolean  @default(true)
  status        String   @default("past")
  liveUrl       String?  @map("live_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("projects")
  @@index([published, featured, order])
}

model Testimonial {
  id        String   @id @default(uuid())
  order     Int
  quoteEn   String   @map("quote_en")
  quoteAr   String   @map("quote_ar")
  authorEn  String   @map("author_en")
  authorAr  String   @map("author_ar")
  roleEn    String   @map("role_en")
  roleAr    String   @map("role_ar")
  rating    Int      @default(5)
  published Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("testimonials")
  @@index([published, order])
}

model PlatformUpdate {
  id        String   @id @default(uuid())
  order     Int      @default(0)
  type      String   @default("news")
  titleEn   String   @map("title_en")
  titleAr   String   @map("title_ar")
  summaryEn String   @map("summary_en")
  summaryAr String   @map("summary_ar")
  date      DateTime @default(now())
  published Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("platform_updates")
  @@index([published, date])
}

model Industry {
  id            String   @id @default(uuid())
  order         Int
  titleEn       String   @map("title_en")
  titleAr       String   @map("title_ar")
  descriptionEn String   @map("description_en")
  descriptionAr String   @map("description_ar")
  published     Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  solutions     Solution[]

  @@map("industries")
  @@index([published, order])
}

model Solution {
  id            String   @id @default(uuid())
  order         Int
  titleEn       String   @map("title_en")
  titleAr       String   @map("title_ar")
  descriptionEn String   @map("description_en")
  descriptionAr String   @map("description_ar")
  published     Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  
  industryId    String?  @map("industry_id")
  industry      Industry? @relation(fields: [industryId], references: [id], onDelete: SetNull)

  @@map("solutions")
  @@index([published, order])
  @@index([industryId])
}

model TeamMember {
  id            String   @id @default(uuid())
  order         Int
  nameEn        String   @map("name_en")
  nameAr        String   @map("name_ar")
  roleEn        String   @map("role_en")
  roleAr        String   @map("role_ar")
  bioEn         String   @map("bio_en")
  bioAr         String   @map("bio_ar")
  descriptionEn String?  @map("description_en")
  descriptionAr String?  @map("description_ar")
  imageUrl      String   @map("image_url")
  resumeUrl     String?  @map("resume_url")
  published     Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  portfolioUrl  String?  @map("portfolio_url")
  linkedinUrl   String?  @map("linkedin_url")

  @@map("our_team")
  @@index([published, order])
}


model Consultation {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  message   String
  status    String   @default("pending")
  seen      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("consultations")
  @@index([status])
  // Common admin query patterns: filter unseen + sort by newest first
  @@index([seen, createdAt(sort: Desc)])
  // Useful for deduplication checks and future spam filtering
  @@index([email])
}

model Package {
  id               String   @id @default(uuid())
  order            Int
  titleEn          String   @map("title_en")
  titleAr          String   @map("title_ar")
  descriptionEn    String?  @map("description_en")
  descriptionAr    String?  @map("description_ar")
  published        Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")


  @@map("packages")
  @@index([published, order])
}
